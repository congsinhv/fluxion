# Fluxion dev environment defaults (local only).
# Copy to `.env` and adjust. `.env` is gitignored.

# ---- PostgreSQL (docker-compose) ----
POSTGRES_DB=fluxion
POSTGRES_USER=fluxion
POSTGRES_PASSWORD=fluxion_dev
POSTGRES_PORT=5432

# ---- LocalStack (docker-compose) ----
LOCALSTACK_PORT=4566
# Optional: LocalStack Pro auth token (leave blank for Community Edition)
LOCALSTACK_AUTH_TOKEN=

# ---- AWS (for Terraform bootstrap and real-cloud flows) ----
AWS_PROFILE=fluxion-dev
AWS_REGION=ap-southeast-1

# ---- Lambda runtime env (referenced in modules/_template/src/config.py) ----
# These are set at deploy by Terraform; local dev reads them via .env when invoking
# handlers through uv run + local test harness.
LOG_LEVEL=DEBUG
POWERTOOLS_SERVICE_NAME=fluxion-dev
DATABASE_URI=postgresql://fluxion:fluxion_dev@localhost:5432/fluxion
